# ============================================================================
# HAPPYPETS ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in with your actual values
# Variables prefixed with NEXT_PUBLIC_ are safe to expose to the browser

# ============================================================================
# SUPABASE (Database, Auth, Realtime)
# ============================================================================
# Get these from: https://app.supabase.com/project/[YOUR-PROJECT]
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_BANNER_BUCKET=banners
# Region: ap-south-1 (Mumbai)
NEXT_PUBLIC_SUPABASE_REGION=ap-south-1

# ============================================================================
# RAZORPAY (Payments)
# ============================================================================
# Get these from: https://dashboard.razorpay.com/#/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret for validating incoming payment updates
RAZORPAY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# ============================================================================
# TOMTOM (Delivery routing & address search)
# ============================================================================
# Get this from: https://developer.tomtom.com/
# Private server key. Do not expose this with VITE_ or NEXT_PUBLIC_.
TOMTOM_API_KEY=your_server_side_tomtom_key
# Optional browser-visible key for admin/customer pin reverse geocoding only.
# Treat VITE_/NEXT_PUBLIC_ values as public.
# The visible map tiles can render without this, but pin-to-address autofill uses the browser key.
VITE_TOMTOM_API_KEY=your_browser_tomtom_key

# ============================================================================
# LOCATIONIQ (Alternative geocoding/routing provider)
# ============================================================================
# Get this from: https://my.locationiq.com/dashboard/
# If present, LocationIQ will be preferred for address search, reverse geocoding, and route calculation.
# Private server key. Do not expose this with VITE_ or NEXT_PUBLIC_.
LOCATIONIQ_API_KEY=your_server_side_locationiq_key
# Optional browser-visible key for pin reverse geocoding only.
VITE_LOCATIONIQ_API_KEY=your_browser_locationiq_key


# ============================================================================
# CLOUDINARY (Image Management & Transformation)
# ============================================================================
# Get these from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=XXXXXXXXXXXXXXXX
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# UPSTASH REDIS (Caching & Sessions)
# ============================================================================
# Get these from: https://console.upstash.io/redis
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AYXXXXXXXXXXXXXXXXXXXXXXc=
# Region: ap-south-1 (Mumbai)
NEXT_PUBLIC_UPSTASH_REGION=ap-south-1

# ============================================================================
# RESEND (Transactional Email)
# ============================================================================
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@thehappypets.in

# ============================================================================
# APP CONFIGURATION
# ============================================================================
NEXT_PUBLIC_APP_URL=https://thehappypets.in
NEXT_PUBLIC_APP_ENV=production
NODE_ENV=production

# For development
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_ENV=development
# NODE_ENV=development

# Mobile app identifiers
NEXT_PUBLIC_MOBILE_APP_ID=com.happypets.app
NEXT_PUBLIC_MOBILE_APP_NAME=Happypets

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXXXXXXXX

# Mixpanel (optional)
# NEXT_PUBLIC_MIXPANEL_TOKEN=XXXXXXXXXXXXXXXX

# Sentry (Error Tracking)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-token

# ============================================================================
# FEATURE FLAGS
# ============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
NEXT_PUBLIC_ENABLE_PAYMENT_TESTING=false

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
# LOG_LEVEL=debug  (use for development)

# ============================================================================
# PERFORMANCE & CACHE
# ============================================================================
# ISR revalidation time (seconds)
NEXT_PUBLIC_ISR_REVALIDATE=3600
# Redis cache TTL (seconds)
NEXT_PUBLIC_REDIS_TTL=300

# ============================================================================
# SMTP (if using custom email instead of Resend)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
