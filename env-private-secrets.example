# Private Secrets Checklist
# Safe to commit as a template because it contains placeholders only.
# Put REAL values only in secret managers or private local env files.

# 1. Supabase Edge Function Secrets
# Place in: Supabase Dashboard -> Project Settings -> Edge Functions -> Secrets

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=server_runtime_anon_key_if_required
SUPABASE_SERVICE_ROLE_KEY=server_only_never_public

RAZORPAY_KEY_ID=optional_server_copy_of_public_key_id
RAZORPAY_KEY_SECRET=server_only_never_public
RAZORPAY_WEBHOOK_SECRET=server_only_never_public

TOMTOM_API_KEY=server_only_never_public
LOCATIONIQ_API_KEY=server_only_never_public
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=server_only_never_public

# Optional CORS / app routing secrets for functions
ALLOWED_ORIGINS=https://thehappypets.in,http://localhost:3004
FRONTEND_URL=https://thehappypets.in

# 2. Server Runtime Secrets
# Place in: Vercel Project Settings -> Environment Variables
# Only needed if that server/runtime actually uses them.

RESEND_API_KEY=server_only_never_public
CLOUDINARY_API_KEY=server_only_prefer_private_runtime
CLOUDINARY_API_SECRET=server_only_never_public

# 3. Local Development Only
# Place in: repo root .env.local
# Keep only if needed for local development and never commit them.

# SUPABASE_SERVICE_ROLE_KEY=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# TOMTOM_API_KEY=
# LOCATIONIQ_API_KEY=
# RESEND_API_KEY=
# UPSTASH_REDIS_REST_TOKEN=
# CLOUDINARY_API_SECRET=

# Rules
# - Never put any private secret in VITE_* or NEXT_PUBLIC_* variables.
# - Browser keys are public by definition.
# - Rotate any secret immediately if it was ever committed or shared.
